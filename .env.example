# Prophet Forecasting Agent - Environment Variables
# Copy this file to .env and fill in your values

# === API Keys (Required) ===
PROPHET_ANTHROPIC_API_KEY=your-anthropic-api-key-here
PROPHET_TAVILY_API_KEY=your-tavily-api-key-here

# === API Keys (Optional) ===
PROPHET_OPENAI_API_KEY=your-openai-api-key-here

# === Server Configuration ===
PROPHET_PORT=8080
PROPHET_HOST=0.0.0.0

# === Model Selection ===
PROPHET_PRIMARY_MODEL=claude-sonnet-4-20250514
PROPHET_BUDGET_MODEL=gpt-4o-mini

# === Processing Limits ===
PROPHET_MAX_CONCURRENCY=10
PROPHET_MAX_SEARCHES_PER_EVENT=3
PROPHET_MAX_LLM_CALLS_PER_EVENT=5
PROPHET_RESPONSE_TIMEOUT_SECONDS=570
PROPHET_PER_EVENT_TIMEOUT_SECONDS=480

# === Cost Management ===
PROPHET_TOTAL_BUDGET_USD=50.0
PROPHET_BUDGET_ALERT_THRESHOLD=0.90

# === Cache ===
PROPHET_CACHE_TTL_HOURS=6

# === Calibration ===
PROPHET_SHRINKAGE_FACTOR=0.15
PROPHET_PLATT_COEFFICIENT=1.732

# === Research ===
PROPHET_EVIDENCE_RECENCY_DAYS=90
PROPHET_MIN_CORROBORATION=1

# === Market Data ===
PROPHET_MARKET_ANCHOR_WEIGHT=0.3
PROPHET_USE_KALSHI_PRICES=true
PROPHET_CONFIDENCE_THRESHOLD=0.05
